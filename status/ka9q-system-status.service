[Unit]
Description=KA9Q SDR System Status Monitor
After=network-online.target

[Service]
Type=simple
User=radio
Group=radio
ExecStart=/opt/ka9q-web/status/venv/bin/python -u system_status.py
WorkingDirectory=/opt/ka9q-web/status
Environment=KA9Q_STATUS_CONF=/opt/ka9q-web/status/system_status.conf
StandardOutput=journal
StandardError=journal
Restart=on-failure
RestartSec=20

[Install]
WantedBy=multi-user.target
