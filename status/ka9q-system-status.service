[Unit]
Description=KA9Q SDR System Status Monitor
After=network-online.target

[Service]
Type=simple
User=radio
Group=radio
ExecStart=/opt/ka9q-web/status/venv/bin/python system_status.py
WorkingDirectory=/opt/ka9q-web/status
Environment=KA9Q_STATUS_CONF=/opt/ka9q-web/status/system_status.conf
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
